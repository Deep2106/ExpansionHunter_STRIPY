/*
========================================================================================
    BASE RESOURCE CONFIGURATION
========================================================================================
    Process labels and default resource allocation
----------------------------------------------------------------------------------------
*/

process {

    // =========================================================================
    // DEFAULT RESOURCES
    // =========================================================================
    cpus   = { check_max( 1, 'cpus' ) }
    memory = { check_max( 2.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h  * task.attempt, 'time' ) }

    errorStrategy = { task.exitStatus in [130,137,139,140,143] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // =========================================================================
    // PROCESS LABEL: process_low
    // Used by: SAMTOOLS_INDEX, WRITE_MANIFEST
    // =========================================================================
    withLabel: 'process_low' {
        cpus   = { check_max( params.samtools_cpus, 'cpus' ) }
        memory = { check_max( params.samtools_memory * task.attempt, 'memory' ) }
        time   = { check_max( 2.h * task.attempt, 'time' ) }
    }

    // =========================================================================
    // PROCESS LABEL: process_medium
    // Used by: EXPANSIONHUNTER
    // NOTE: ExpansionHunter v5 is single-threaded (1 CPU only)
    // =========================================================================
    withLabel: 'process_medium' {
        cpus   = { check_max( params.expansionhunter_cpus, 'cpus' ) }
        memory = { check_max( params.expansionhunter_memory * task.attempt, 'memory' ) }
        time   = { check_max( 48.h * task.attempt, 'time' ) }
    }

    // =========================================================================
    // PROCESS LABEL: process_single
    // Used by: WRITE_MANIFEST
    // =========================================================================
    withLabel: 'process_single' {
        cpus   = { check_max( 1, 'cpus' ) }
        memory = { check_max( params.manifest_memory, 'memory' ) }
        time   = { check_max( 1.h, 'time' ) }
    }

    // =========================================================================
    // PROCESS LABEL: process_low
    // Updated: also covers STRipy annotate + report steps
    // =========================================================================

    // =========================================================================
    // PROCESS LABEL: process_aggregate
    // Used by: STRIPY_AGGREGATE_COHORT_REPORT
    // Needs more memory for Excel generation across 252 samples
    // =========================================================================
    withLabel: 'process_aggregate' {
        cpus   = { check_max( params.stripy_aggregate_cpus, 'cpus' ) }
        memory = { check_max( params.stripy_aggregate_memory * task.attempt, 'memory' ) }
        time   = { check_max( 4.h * task.attempt, 'time' ) }
    }
}
